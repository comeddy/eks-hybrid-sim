# ============================================================
# DEV 환경 — terraform.tfvars
# cp terraform.tfvars.example terraform.tfvars 후 실제 값 입력
# ============================================================

aws_region       = "ap-northeast-2"
base_domain      = "sim.example.com"
eks_cluster_name = "my-eks-cluster"
ecr_registry     = "<ACCOUNT_ID>.dkr.ecr.ap-northeast-2.amazonaws.com"
helm_chart_path  = "../../eks-simulator-helm"

hybrid_node_enabled = false

# ============================================================
# OEM & User 정의
#
# 서비스별 오버라이드:
#   services 맵에 해당 서비스의 image_tag, replicas를 지정.
#   생략된 서비스는 Helm chart 기본값 (latest, replicas=1) 사용.
#
# 유저 추가: users 블록에 항목 추가 후 terraform apply
# 유저 삭제: users 블록에서 항목 제거 후 terraform apply
# ============================================================
oem_users = {

  # ---- Hyundai ----
  hyundai = {
    users = {
      user-a = {
        services = {
          simulator-server = { image_tag = "v1.3.0" }
          simulator-can    = { image_tag = "v1.2.0" }
        }
      }
      user-b = {
        # 모든 서비스 기본값 (latest)
      }
      user-c = {
        services = {
          simulator-server = { image_tag = "v1.3.0", replicas = 2 }
        }
      }
    }
  }

  # ---- KIA ----
  kia = {
    users = {
      user-a = {
        services = {
          simulator-vehicle = { image_tag = "v2.0.0" }
        }
      }
    }
  }

  # ---- 신규 OEM 추가 예시 ----
  # toyota = {
  #   users = {
  #     user-a = {}
  #   }
  # }
}
